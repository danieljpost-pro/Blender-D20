{
  "_comment": "Dramatic 'critical hit' rendering: dark transparent die, fast spin, banner + audio.",

  "die": {
    "body_color": [0.05, 0.05, 0.10, 1.0],
    "body_roughness": 0.15,
    "body_transmission": 0.5,
    "body_ior": 1.55,
    "number_color": [1.0, 0.85, 0.2, 1.0],
    "mass": 0.018
  },

  "physics": {
    "initial_position": [-0.22, 0.12, 0.18],
    "initial_linear_velocity": [1.6, -0.7, 0.3],
    "initial_angular_velocity": [16.0, 10.0, 18.0]
  },

  "lighting": {
    "key_energy": 110.0,
    "rim_energy": 80.0,
    "background_color": [0.02, 0.02, 0.03, 1.0]
  },

  "banner": {
    "enabled": true,
    "text_template": "CRITICAL HIT! ({value})",
    "font_size_px": 110,
    "text_color": [1.0, 0.9, 0.3, 1.0],
    "outline_color": [0.4, 0.0, 0.0, 1.0],
    "outline_width_px": 6,
    "background_color": [0.0, 0.0, 0.0, 0.7],
    "scroll_direction": "left",
    "scroll_duration_frames": 18,
    "hold_frames": 90
  },

  "banner_audio": {
    "enabled": true,
    "sting_enabled": true,
    "sting_default_path": "/path/to/fanfare.wav",
    "sting_per_outcome": {
      "20": "/path/to/crit_hit.wav",
      "1":  "/path/to/critical_fail.wav"
    },
    "sting_volume": 1.0,
    "ambience_enabled": true,
    "ambience_default_path": "/path/to/tavern_loop.ogg",
    "ambience_volume": 0.3,
    "ambience_loop": true,
    "ambience_fade_in_frames": 12,
    "ambience_fade_out_frames": 18
  },

  "render": {
    "samples": 256,
    "use_denoiser": true,
    "use_motion_blur": true,
    "fps": 30
  },

  "desired_outcomes": [20]
}
